#!/bin/sh
# Maven Wrapper for Unix/Mac
# Auto-downloads Maven if not present
WRAPPER_JAR="$HOME/.m2/wrapper/dists/maven-wrapper.jar"
DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper..."
    mkdir -p "$(dirname "$WRAPPER_JAR")"
    curl -o "$WRAPPER_JAR" "$DOWNLOAD_URL" 2>/dev/null || wget -O "$WRAPPER_JAR" "$DOWNLOAD_URL"
fi

exec java -cp "$WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
