# ============================================================
# AI ARCHITECT BACKEND — API KEYS
# Fill these in before running the backend.
# All keys are optional — the system uses whatever is available.
# ============================================================

# --- Gemini (Primary - Recommended) ---
# Get free keys at: https://aistudio.google.com/apikey
GEMINI_KEY_1=YOUR_GEMINI_KEY_1
GEMINI_KEY_2=YOUR_GEMINI_KEY_2

# --- OpenRouter (Free model access) ---
# Get free key at: https://openrouter.ai/keys
OPENROUTER_KEY_1=YOUR_OPENROUTER_KEY_1
OPENROUTER_KEY_2=YOUR_OPENROUTER_KEY_2

# --- Groq (Fast & free tier) ---
# Get free key at: https://console.groq.com/keys
GROQ_KEY_1=YOUR_GROQ_KEY_1
GROQ_KEY_2=YOUR_GROQ_KEY_2

# --- Together AI (Free models) ---
# Get free key at: https://api.together.xyz/settings/api-keys
TOGETHER_KEY_1=YOUR_TOGETHER_KEY_1
TOGETHER_KEY_2=YOUR_TOGETHER_KEY_2

# --- Cerebras (Free tier) ---
# Get free key at: https://cloud.cerebras.ai
CEREBRAS_KEY_1=YOUR_CEREBRAS_KEY_1
CEREBRAS_KEY_2=YOUR_CEREBRAS_KEY_2

# --- Redis (local, usually no changes needed) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth (optional, desktop mode works without this) ---
AUTH_ENABLED=false
JWT_SECRET=change-this-to-a-random-32-char-string-in-production
JWT_EXPIRY_HOURS=24
LOCAL_PASSWORD=

# --- Python Worker ---
PYTHON_WORKER_URL=http://localhost:8081

# --- PostgreSQL ---
DATABASE_URL=jdbc:postgresql://localhost:5432/ai_architect
DATABASE_USER=ai_architect
DATABASE_PASSWORD=ai_architect
